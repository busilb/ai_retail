# 本地开发 - 复制为 .env.local 并填值

# NextAuth：随机 32 字节 base64，本地 node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=replace-me-with-random-32-bytes

# 本地数据库（开发用）
DB_PATH=./data/jinshou.db

# 部署用 Turso（设置后 client 自动切到远程）
# 1. https://app.turso.tech/signup
# 2. 创建数据库 → 拿 URL
# 3. turso db tokens create <db-name>
# TURSO_DATABASE_URL=libsql://xxx-xxx.aws-ap-northeast-1.turso.io
# TURSO_AUTH_TOKEN=eyJhbGciOi...

# LLM（可选 - 不填走规则引擎 mock）
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-7
